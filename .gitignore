# Terraform
# Downloaded provider plugins (large, re-downloadable)
**/.terraform/
# State files (contain sensitive info like resource IDs)
*.tfstate
*.tfstate.backup
# Variable files (may contain secrets)
*.tfvars
# Lock file (regenerated by terraform init)
.terraform.lock.hcl

# OS
.DS_Store

# Credentials (never commit these)
*.pem
*.key
.env
